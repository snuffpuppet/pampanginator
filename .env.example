# Kapampangan Tutor — Environment Variables
#
# Copy this file to .env and fill in the values marked REQUIRED.
# Variables with defaults shown can be left as-is for local development.
#
# Usage:
#   cp .env.example .env
#   docker compose up

# =============================================================================
# SHARED — PostgreSQL (all three postgres instances use this password)
# =============================================================================

# Password for all three postgres instances (app-postgres, vocab-postgres,
# grammar-postgres). All use username=kapampangan and db=kapampangan.
# REQUIRED.
POSTGRES_PASSWORD=change_me_in_production

# =============================================================================
# APP SERVICE — orchestration layer + React frontend
# =============================================================================

# LLM backend selection. Only "openrouter" is supported in production.
# Default: openrouter
BACKEND=openrouter

# OpenRouter API key. Required for the LLM to work.
# Get one at https://openrouter.ai/keys
# REQUIRED.
OPENROUTER_API_KEY=

# Active model for single-model chat (GET /api/chat).
# If unset, falls back to OPENROUTER_MODEL_A.
# Example: anthropic/claude-sonnet-4-6
OPENROUTER_MODEL=

# Model A — used for /api/chat/model-a and as the default active model.
# Default: anthropic/claude-sonnet-4-6
OPENROUTER_MODEL_A=anthropic/claude-sonnet-4-6

# Model B — used for /api/chat/model-b in comparison mode.
# Default: meta-llama/llama-3.1-8b-instruct
OPENROUTER_MODEL_B=meta-llama/llama-3.1-8b-instruct

# Internal URL the app uses to reach the vocabulary service.
# In Docker Compose this resolves via the service name. Override for external deployments.
# Default: http://mcp-vocabulary:8001
VOCABULARY_SERVICE_URL=http://mcp-vocabulary:8001

# Internal URL the app uses to reach the grammar service.
# Default: http://grammar:8002
GRAMMAR_SERVICE_URL=http://grammar:8002

# Optional. If set, the /admin page requires this password.
# If unset, /admin is accessible without a password (development convenience).
VITE_ADMIN_PASSWORD=

# =============================================================================
# MCP-VOCABULARY SERVICE — vocabulary MCP server
# =============================================================================

# Set to "true" to truncate and reseed the vocabulary table from
# mcp-vocabulary/data/vocabulary.json on every startup. Useful after pulling updated
# canonical data. Expensive — leave false in normal operation.
# Default: false
RESEED_ON_STARTUP=false

# =============================================================================
# GRAMMAR SERVICE — grammar MCP server
# =============================================================================
# (Also uses RESEED_ON_STARTUP above — applies independently to each service.)

# =============================================================================
# OBSERVABILITY — shared across all three application services
# =============================================================================

# OpenTelemetry collector endpoint. Services send spans here.
# Default: http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Deployment environment tag attached to all traces and metrics.
# Default: development
ENVIRONMENT=development

# Service version tag attached to all traces and metrics.
# Default: 0.1.0
SERVICE_VERSION=0.1.0

# Python log level for all services. DEBUG produces verbose output.
# Default: INFO
LOG_LEVEL=INFO

# =============================================================================
# GRAFANA
# =============================================================================

# Grafana admin UI password. Change in production.
# Default: admin
GF_SECURITY_ADMIN_PASSWORD=admin
