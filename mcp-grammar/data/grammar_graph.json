    { "id": "gewa", "type": "verb_form", "meaning": "did / made" },
    { "id": "gawan", "type": "verb_form", "meaning": "will do / make" },

    { "id": "muli", "type": "verb_root", "meaning": "to go home" },
    { "id": "mamuli", "type": "verb_form", "meaning": "is going home / will go home" },
    { "id": "memuli", "type": "verb_form", "meaning": "went home" }
  ],

