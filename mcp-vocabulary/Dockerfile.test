FROM python:3.12-slim
WORKDIR /app

# Install service dependencies then test dependencies.
# Source is provided at runtime via a volume mount, so only deps are baked in.
COPY libs/ /libs/
COPY mcp-vocabulary/requirements.txt mcp-vocabulary/requirements-test.txt ./
RUN pip install --no-cache-dir /libs/kapampangan_obs -r requirements.txt -r requirements-test.txt && \
    rm -rf /libs/

CMD ["python", "-m", "pytest", "tests", "-v"]
