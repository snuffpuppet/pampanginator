{
  "title": "Kapampangan Tutor — Observability",
  "uid": "kapampangan-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["kapampangan", "observability"],
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "System Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate",
      "description": "Requests per second across all services",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(kapampangan_requests_total[1m]))",
        "legendFormat": "req/s"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "description": "Percentage of requests returning 5xx status",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(kapampangan_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(kapampangan_requests_total[5m]))",
        "legendFormat": "error rate"
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "p50 Latency",
      "description": "Median end-to-end request duration",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.5, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
        "legendFormat": "p50"
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "p99 Latency",
      "description": "99th percentile end-to-end request duration",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.99, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
        "legendFormat": "p99"
      }]
    },

    {
      "id": 10,
      "type": "row",
      "title": "Request Latency — click exemplar dots to open traces in Tempo",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "End-to-End Request Duration (with trace exemplars)",
      "description": "Click any dot on the chart to open the associated trace in Tempo",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
          "legendFormat": "p50",
          "exemplar": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
          "legendFormat": "p95",
          "exemplar": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
          "legendFormat": "p99",
          "exemplar": true
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "Latency Breakdown by Stage",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "LLM Call Duration (Anthropic API)",
      "description": "Time spent waiting for the Anthropic API — the dominant latency component",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(kapampangan_llm_call_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p50 {{model}}",
          "exemplar": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_llm_call_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p99 {{model}}",
          "exemplar": true
        }
      ]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "MCP Server Call Duration",
      "description": "Vocabulary and grammar server response times",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_vocabulary_lookup_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "vocabulary p99",
          "exemplar": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_grammar_traversal_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "grammar p99",
          "exemplar": true
        }
      ]
    },

    {
      "id": 30,
      "type": "row",
      "title": "LLM Usage",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "Token Consumption Rate",
      "description": "Input and output tokens per minute — use to track prompt growth and cost",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kapampangan_llm_tokens_total{direction=\"input\"}[5m])) * 60",
          "legendFormat": "input tokens/min"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kapampangan_llm_tokens_total{direction=\"output\"}[5m])) * 60",
          "legendFormat": "output tokens/min"
        }
      ]
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "Tool Call Rate by Tool",
      "description": "How often the agent is using vocabulary vs grammar lookups",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(kapampangan_tool_calls_total[5m])) by (tool_name)",
        "legendFormat": "{{tool_name}}"
      }]
    },

    {
      "id": 40,
      "type": "row",
      "title": "MCP Server Intelligence",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "Vocabulary Lookup Results",
      "description": "Found vs not-found rate — high not_found may indicate vocabulary gaps",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(kapampangan_vocabulary_lookups_total[5m])) by (result)",
        "legendFormat": "{{result}}"
      }]
    },

    {
      "id": 42,
      "type": "timeseries",
      "title": "Grammar Traversals by Relationship Type",
      "description": "Which grammar relationships are being queried most",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(kapampangan_grammar_traversals_total[5m])) by (relationship)",
        "legendFormat": "{{relationship}}"
      }]
    },

    {
      "id": 50,
      "type": "row",
      "title": "Trace Explorer — jump from metrics to traces",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 51,
      "type": "traces",
      "title": "Recent Traces — kapampangan-app",
      "description": "Live trace list. Click any trace to inspect the full span tree.",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "traceql",
        "query": "{ resource.service.name = \"kapampangan-app\" }",
        "limit": 20
      }]
    }

  ],

  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kapampangan_requests_total, service)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  }
}
