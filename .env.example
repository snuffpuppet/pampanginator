# Copy this file to .env and set only what you need to override.
# Defaults for BACKEND, OLLAMA_MODEL, and OLLAMA_URL are in config/llm.yaml.
# ANTHROPIC_API_KEY has no default and must be set when using the Anthropic backend.

# ── Backend selection ──────────────────────────────────────────────────────────
# Overrides active_backend in config/llm.yaml.
# 'anthropic' — Claude API (best quality, requires ANTHROPIC_API_KEY)
# 'ollama'    — local LLM, free & offline (requires Ollama running)
# BACKEND=anthropic

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required when BACKEND=anthropic. No default.
# ANTHROPIC_API_KEY=your_key_here

# ── Ollama overrides ───────────────────────────────────────────────────────────
# Only needed if you want to use a different model or URL than the llm.yaml defaults.
# Install:  brew install ollama
# Pull:     ollama pull <model>
# Run:      ollama serve
# OLLAMA_MODEL=llama3.2
# OLLAMA_URL=http://host.docker.internal:11434
