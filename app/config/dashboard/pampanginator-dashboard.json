{
  "title": "Kapampangan Tutor \u2014 Observability",
  "uid": "kapampangan-main",
  "schemaVersion": 38,
  "version": 1,
  "orgId": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "kapampangan",
    "observability"
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "System Health",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate",
      "description": "Requests per second across all services",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(kapampangan_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Count (5m)",
      "description": "Number of error responses in the last 5 minutes (4xx except 404, plus all 5xx) \u2014 turns red on any single error. 404 is excluded because the vocabulary service correctly returns 404 for unknown words.",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(kapampangan_requests_total{status_code=~\"[45]..\",status_code!=\"404\"}[5m]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "LLM Errors",
      "description": "Errors from the LLM backend (Anthropic or Ollama) \u2014 these return HTTP 200 so they are invisible to the HTTP error rate panel",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 4,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(kapampangan_llm_errors_total[5m]))",
          "legendFormat": "LLM errors"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors by Status Code",
      "description": "Rate of 4xx and 5xx responses \u2014 4xx often indicate route mismatches or bad requests; 5xx indicate server errors",
      "gridPos": {
        "x": 4,
        "y": 5,
        "w": 20,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "4xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "5xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "4xx",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (endpoint, status_code) (rate(kapampangan_requests_total{status_code=~\"4..\"}[1m]))",
          "legendFormat": "{{status_code}} {{endpoint}}"
        },
        {
          "refId": "5xx",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (endpoint, status_code) (rate(kapampangan_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "{{status_code}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p50 Latency",
      "description": "Median end-to-end request duration",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.5, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p99 Latency",
      "description": "99th percentile end-to-end request duration",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Request Latency \u2014 click exemplar dots to open traces in Tempo",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "End-to-End Request Duration (with trace exemplars)",
      "description": "Click any dot on the chart to open the associated trace in Tempo",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
          "legendFormat": "p50",
          "exemplar": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
          "legendFormat": "p95",
          "exemplar": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_request_duration_seconds_bucket{service=\"kapampangan-app\"}[5m])) by (le))",
          "legendFormat": "p99",
          "exemplar": true
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Latency Breakdown by Stage",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "LLM Call Duration",
      "description": "Time spent waiting for the LLM backend \u2014 the dominant latency component",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(kapampangan_llm_call_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p50 {{model}}",
          "exemplar": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_llm_call_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p99 {{model}}",
          "exemplar": true
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "MCP Server Call Duration",
      "description": "Vocabulary and grammar server response times",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_vocabulary_lookup_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "vocabulary p99",
          "exemplar": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(kapampangan_grammar_traversal_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "grammar p99",
          "exemplar": true
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "LLM Usage",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Token Consumption Rate",
      "description": "Input and output tokens per minute \u2014 use to track prompt growth and cost",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(kapampangan_llm_tokens_total{direction=\"input\"}[5m])) * 60",
          "legendFormat": "input tokens/min"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(kapampangan_llm_tokens_total{direction=\"output\"}[5m])) * 60",
          "legendFormat": "output tokens/min"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Tool Call Rate by Tool",
      "description": "How often the agent is using vocabulary vs grammar lookups",
      "gridPos": {
        "x": 12,
        "y": 30,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(kapampangan_tool_calls_total[5m])) by (tool_name)",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "MCP Server Intelligence",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Vocabulary Lookup Results",
      "description": "Found vs not-found rate \u2014 high not_found may indicate vocabulary gaps",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(kapampangan_vocabulary_lookups_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Grammar Traversals by Relationship Type",
      "description": "Which grammar relationships are being queried most",
      "gridPos": {
        "x": 12,
        "y": 38,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(kapampangan_grammar_traversals_total[5m])) by (relationship)",
          "legendFormat": "{{relationship}}"
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "Trace Explorer \u2014 jump from metrics to traces",
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 51,
      "type": "table",
      "title": "Recent Traces \u2014 kapampangan-app",
      "description": "Live trace list. Click any trace to inspect the full span tree.",
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"kapampangan-app\" }",
          "limit": 20
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "nested"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "traceID"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Trace ID"
              },
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open trace",
                    "url": "/explore?left=%7B%22datasource%22%3A%22tempo%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22queryType%22%3A%22traceId%22%2C%22query%22%3A%22%24%7B__value.raw%7D%22%7D%5D%7D"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 60,
      "type": "row",
      "title": "Logs \u2014 structured JSON with trace correlation (click TraceID to open in Tempo)",
      "gridPos": {
        "x": 0,
        "y": 56,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 61,
      "type": "logs",
      "title": "App Logs",
      "gridPos": {
        "x": 0,
        "y": 57,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"app\"} | json"
        }
      ]
    },
    {
      "id": 62,
      "type": "logs",
      "title": "Vocabulary MCP Logs",
      "gridPos": {
        "x": 8,
        "y": 57,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"vocab\"} | json"
        }
      ]
    },
    {
      "id": 63,
      "type": "logs",
      "title": "Grammar MCP Logs",
      "gridPos": {
        "x": 16,
        "y": 57,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"grammar\"} | json"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kapampangan_requests_total, service)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  }
}