# Copy this file to .env and set only what you need to override.
# Defaults for BACKEND and model are in config/llm.yaml.
# OPENROUTER_API_KEY has no default and must be set.

# ── Backend selection ──────────────────────────────────────────────────────────
# Overrides active_backend in config/llm.yaml.
# BACKEND=openrouter

# ── OpenRouter ─────────────────────────────────────────────────────────────────
# Required. Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=${OPENROUTER_API_KEY}

# ── Model override ─────────────────────────────────────────────────────────────
# Overrides the model in config/llm.yaml. Leave unset to use the yaml default.
# Examples: anthropic/claude-sonnet-4-6  meta-llama/llama-3.1-8b-instruct
# OPENROUTER_MODEL=

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Required. Used by all three application services.
# POSTGRES_PASSWORD=changeme

# ── Knowledge sharing ──────────────────────────────────────────────────────────
# Set to true to reseed the database from data/ on every container restart.
# Useful after pulling updated canonical files from the repository.
# RESEED_ON_STARTUP=false

# ── Admin interface ────────────────────────────────────────────────────────────
# Optional. If set, the /admin page requires this password to access.
# If unset, /admin is accessible without a password (development convenience).
# VITE_ADMIN_PASSWORD=changeme

# ── Compare page models ────────────────────────────────────────────────────────
# The two models shown side-by-side on the Compare page (dev mode only).
# Both panels call OpenRouter — differentiated by model only.
# OPENROUTER_MODEL_A=anthropic/claude-sonnet-4-6
# OPENROUTER_MODEL_B=meta-llama/llama-3.1-8b-instruct
